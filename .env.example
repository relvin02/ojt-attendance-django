# Environment variables for PythonAnywhere deployment
# Copy this file as .env on PythonAnywhere and fill in your values

# Django Security
SECRET_KEY=your-secret-key-here-generate-a-strong-one-in-production
DEBUG=False

# Allowed hosts (update with your PythonAnywhere domain)
ALLOWED_HOSTS=rgcoder.pythonanywhere.com,www.rgcoder.pythonanywhere.com,localhost,127.0.0.1

# Database (using SQLite by default)
# For production, consider using PostgreSQL
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Optional: Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Optional: External API Keys
# Add any external API keys here if your app uses them
